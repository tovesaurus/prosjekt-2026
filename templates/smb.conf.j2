#============================   Shared Folders   ==============================
[shares]
    comment = Filserver for Andora Arkitekter
    path = /srv/shares
    browseable = yes
    read only = yes
    guest ok = no
    valid users = @"domain users"

[felles]
    comment = Felles mappe for Andora Arkitekters ansatte
    path = /srv/shares/felles
    browseable = yes
    read only = no
    guest ok = no
    valid users = @"domain users"
    force group = "domain users"
    create mask = 0664
    directory mask = 2775

